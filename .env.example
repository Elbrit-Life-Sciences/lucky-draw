# ERPNext / Forms Pro connection for capturing lucky-draw entries.
# The app submits via the Forms Pro public (guest) endpoint, so NO API key or
# secret is needed. These are optional overrides with sensible defaults.
# Copy to .env.local for local dev; set in Netlify for production if overriding.

# Base URL of the ERPNext site hosting the Forms Pro "Lucky Draw" form.
ERP_URL=https://erp.elbrit.org

# Forms Pro Form id (route forms_pro_B4sebvHN -> Form id 7upn0fs2f5).
FORMS_PRO_FORM_ID=7upn0fs2f5
