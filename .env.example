# ERPNext connection for capturing lucky-draw entries into the Forms Pro
# "Lucky Draw" form (route forms_pro_B4sebvHN).
# Copy to .env.local for local dev; set the same keys in Netlify
# (Site settings → Environment variables) for production.
# Never commit real values.

ERP_URL=https://erp.elbrit.org
ERP_API_KEY=your_api_key
ERP_API_SECRET=your_api_secret

# Submission DocType the Forms Pro form writes to.
# Defaults to formspro_ragbwi000001 if unset.
ERP_DOCTYPE=formspro_ragbwi000001
